{
  "name": "Anchor Alarm",
  "version": "0.3",
  "author": "Alexander Yamshanov",
  "description": "Track position drift",
  "type": "feature",
  "usage": "workout",
  "modificationTime": 1777661530,
  "image": [
    { "name": "arrow-a64.png", "type": "a64" }
  ],
  "in": [
    {
      "name": "gpsReadiness",
      "source": "/Fusion/Location/Readiness",
      "type": "subscribe"
    },
    {
      "name": "latitude",
      "source": "/Fusion/Location/GeoCoordinates.latitude",
      "type": "subscribe"
    },
    {
      "name": "longitude",
      "source": "/Fusion/Location/GeoCoordinates.longitude",
      "type": "subscribe"
    },

    {
      "name": "Heading",
      "source": "/Fusion/Compass/Heading",
      "type": "subscribe"
    }
  ],
  "out": [
    { "name": "gpsReady" },
    { "name": "alarmRadius" },
    { "name": "watchState" },
    { "name": "distanceToAnchor" },
    { "name": "relBearingToAnchor" },
    { "name": "alarmCount" }
  ],
  "template": [
    { "name": "t_setup.html" },
    { "name": "t_watch.html" },
    { "name": "t_popup.html" }
  ],
  "variables": [
    { "shownName": "Alarm radius (m)", "path": "alarmRadius", "type": "string" }
  ]
}